# nikki on the 256MB variant only — cudy_tr3000-v1 has no room for it plus its
# mihomo core. Both devices share this one .config, so the split is expressed
# per device rather than per build:
#
#   =m            builds the .ipk but keeps it out of every rootfs
#   TARGET_DEVICE_PACKAGES  installs it into just this device's rootfs
#
# The second symbol carries no 'select', so dropping the first line would
# silently produce firmware without nikki: nothing would ever compile it.
# Dependencies (the mihomo core, whose package name varies) are resolved from
# what =m built — do not list them here.
CONFIG_PACKAGE_luci-app-nikki=m
CONFIG_TARGET_DEVICE_PACKAGES_mediatek_filogic_DEVICE_cudy_tr3000-256mb-v1="luci-app-nikki"
