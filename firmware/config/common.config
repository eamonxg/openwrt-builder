# common base for every build
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_zh_Hans=y

# initramfs is left at the upstream default on purpose. For every router here it
# is the ONLY way in: their sysupgrade images are 'sysupgrade-tar', which no
# bootloader can write to flash, so a first install must tftp an initramfs image
# and run sysupgrade from the OpenWrt it boots. Targets opting out say so in
# their own overlay (see x86.config).

# third-party plugins every build gets; packages.ini clones their repos.
# Anything only some builds have room for goes in firmware/config/<name>.config instead.
#
# Proxy policy: passwall2 is the ONE default proxy, on every device. Any proxy
# app beyond it (today just nikki) is never a default — it is granted per
# device, to big-RAM/big-flash hardware only, in that build's overlay: nikki on
# x86 and the 256MB tr3000. See those files.
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-theme-shadcn=y
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y
