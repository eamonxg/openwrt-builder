# OpenClash on Arthur (jdcloud_re-ss-01) only. Athena (jdcloud_re-cs-02) shares
# this .config but does not get it.
#
# openclash DEPENDS +dnsmasq-full, which conflicts with the default dnsmasq.
# dnsmasq is a base rootfs package, so the swap cannot be scoped per device — it
# is build-wide here, and both boards end up on dnsmasq-full (a harmless
# superset). The app itself IS per-device: =m builds the .ipk without putting it
# in any rootfs, and the device-package line installs it into Arthur's rootfs
# alone — the same two-line mechanism as nikki in tr3000.config. openclash's own
# dependencies (ruby, kmod-tun, ...) are pulled in by =m; do not list them.
# The meta core ships inside the ipk too, placed there by preset-openclash-core.sh.
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_luci-app-openclash=m
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01="luci-app-openclash"
