# OpenClash on Arthur (jdcloud_re-ss-01) only. Athena (jdcloud_re-cs-02) shares
# this .config but does not get the app.
#
# openclash DEPENDS +dnsmasq-full, which supplants the default dnsmasq: it
# PROVIDES dnsmasq and, as =y, lands in every rootfs, so each device's 'dnsmasq'
# rootfs default is satisfied by it and the stock .ipk is installed nowhere. No
# explicit dnsmasq-full=y line is needed: passwall2's transparent-proxy option
# already selects it =y build-wide (common.config) and openclash's own
# +dnsmasq-full would pull it in regardless — x86 and tr3000, which carry no
# such line, resolve to dnsmasq-full=y all the same. And no dnsmasq=n line
# either: a per-device-rootfs build force-selects every device-default package
# to =m (MODULE_DEFAULT_*, so the per-device lists have .ipks to install from),
# so defconfig bounces the n right back and the guard fails the build.
# The app itself IS per-device: =m builds the .ipk without putting it in any
# rootfs, and the device-package line installs it into Arthur's rootfs alone —
# the same two-line mechanism as nikki in tr3000.config. openclash's own
# dependencies (ruby, kmod-tun, ...) are pulled in by =m; do not list them.
# The meta core ships inside the ipk too, placed there by preset-openclash-core.sh.
CONFIG_PACKAGE_luci-app-openclash=m
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01="luci-app-openclash"
