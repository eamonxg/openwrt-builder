# OpenClash on Arthur (jdcloud_re-ss-01) only. Athena (jdcloud_re-cs-02) shares
# this .config but does not get it.
#
# openclash DEPENDS +dnsmasq-full, which supplants the default dnsmasq: =y puts
# it in every rootfs of this build, and because it PROVIDES dnsmasq, each
# device's 'dnsmasq' rootfs default is satisfied by it — the stock .ipk is
# still built, but installed nowhere. Deliberately no dnsmasq=n line: a
# per-device-rootfs build force-selects every device-default package to =m
# (MODULE_DEFAULT_*, so the per-device lists have .ipks to install from), so
# defconfig bounces the n right back and the guard fails the build. passwall2's
# transparent-proxy option already selects dnsmasq-full=y build-wide; the line
# here records that openclash needs it regardless of passwall2's defaults.
# The app itself IS per-device: =m builds the .ipk without putting it in any
# rootfs, and the device-package line installs it into Arthur's rootfs alone —
# the same two-line mechanism as nikki in tr3000.config. openclash's own
# dependencies (ruby, kmod-tun, ...) are pulled in by =m; do not list them.
# The meta core ships inside the ipk too, placed there by preset-openclash-core.sh.
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_luci-app-openclash=m
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01="luci-app-openclash"
