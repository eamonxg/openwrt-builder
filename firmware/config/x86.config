# nikki: only this build has the flash for it plus its mihomo core
CONFIG_PACKAGE_luci-app-nikki=y

# larger rootfs to fit passwall2/nikki and their cores
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_IMAGES_GZIP=y
# squashfs-combined-efi only: drop ext4 images, legacy BIOS images and rootfs tarballs
CONFIG_TARGET_ROOTFS_EXT4FS=n
CONFIG_GRUB_IMAGES=n
CONFIG_TARGET_ROOTFS_TARGZ=n
