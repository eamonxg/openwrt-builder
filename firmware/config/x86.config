# nikki: an extra beside the default passwall2 (see the proxy policy in
# common.config), granted here because x86 is the fleet's big-RAM/big-flash
# machine. This build has a single rootfs — builds.ini lists no devices, so
# there is no per-device mechanism — which makes =y on the whole build the
# single-machine equivalent of tr3000's "=m plus device-package line".
CONFIG_PACKAGE_luci-app-nikki=y

# larger rootfs to fit passwall2/nikki and their cores
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_IMAGES_GZIP=y

# x86 installs by writing a whole disk, so there is no "boot something temporary
# first" step: its initramfs product is just a bzImage with the rootfs inlined,
# useful only for netboot. The routers need the opposite (see common.config).
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# Image formats. GRUB_EFI_IMAGES / GRUB_IMAGES / TARGET_ROOTFS_EXT4FS already
# default to y upstream; they are written out anyway because this file is the
# record of what we ship, and an upstream default flip must not change it in
# silence. ISO_IMAGES has no default at all and only works with a GRUB variant on.
# UEFI whole-disk image
CONFIG_GRUB_EFI_IMAGES=y
# legacy BIOS whole-disk image: PVE on seabios and older boards boot nothing else
CONFIG_GRUB_IMAGES=y
# resizable root; the squashfs variant cannot grow
CONFIG_TARGET_ROOTFS_EXT4FS=y
# bootable install media
CONFIG_ISO_IMAGES=y

# no VMDK: PVE/KVM import the .img directly and VirtualBox converts on its own,
# while VMDK is uncompressed and the bulkiest of the lot. Add CONFIG_VMDK_IMAGES=y
# if an ESXi host ever needs it.

# rootfs tarballs are not flashable on their own
CONFIG_TARGET_ROOTFS_TARGZ=n
